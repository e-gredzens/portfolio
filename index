    <div class="grid">
        <div class="item">
            <iframe src="html5-banners/demo-banner/index.html"></iframe>
            <p>Demo HTML5 baneris</p>
        </div>
    </div>
</section>

<section id="anim">
    <h2>2D Animācijas</h2>
    <div class="grid">
        <div class="item">
            <video controls>
                <source src="assets/videos/anim-demo.mp4" type="video/mp4">
