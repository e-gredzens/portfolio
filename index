    <h2>Web Dizains</h2>
    <div class="grid">

        <div class="item">
            <img src="web-design/project1/screenshot1.jpg">
            <h3>Coffee Landing Page</h3>
            <p>Paveiktais: dizains + kodēšana</p>
            <a href="https://example.com/coffee-demo" target="_blank">Apskatīt</a>
        </div>

        <div class="item">
            <img src="web-design/project2/screenshot1.jpg">
            <h3>Portfolio Website</h3>
            <p>Paveiktais: tikai dizains</p>
