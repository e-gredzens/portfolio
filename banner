body { margin: 0; }
.banner {
    width: 300px;
    height: 250px;
    background: linear-gradient(135deg, #ddd, #aaa);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    animation: fadein 1.5s ease forwards;
}
.text {
    font-size: 24px;
    opacity: 0;
    animation: slide 1s ease forwards 0.5s;
}
.cta {
    margin-top: 20px;
    padding: 10px 20px;
    background: #333;
    color: white;
    border: none;
    cursor: pointer;
    opacity: 0;
    animation: fadein 1s ease forwards 1.2s;
}
@keyframes fadein { from {opacity:0;} to {opacity:1;} }
@keyframes slide { from {transform:translateY(20px); opacity:0;} to {transform:translateY(0); opacity:1;} }
